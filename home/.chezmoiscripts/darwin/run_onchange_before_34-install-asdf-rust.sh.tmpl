#!/bin/bash

# {{ template "common-lib.sh" . }}
# {{ template "asdf-lib.sh" . }}

log_info '[MacOS - 034] Install Rust via Asdf.'

# shellcheck disable=SC2154
ensure_path_entry "${asdf_prefix}/bin"

if ! is_asdf_plugin_installed 'rust'; then
  log_warning '[MacOS - 034] Asdf Rust plugin not installed.'
  log_task '[MacOS - 034] Installing Asdf Rust plugin...'

  asdf plugin add rust https://github.com/asdf-community/asdf-rust.git
fi

readonly wanted_versions=(
  "1.74.1"
)

for version in "${wanted_versions[@]}"; do
  if ! is_asdf_package_installed 'rust' "${version}"; then
    log_warning "[MacOS - 034] Rust ${version} not installed."
    log_task "[MacOS - 034] Installing Rust ${version}..."
    asdf install 'rust' "${version}"
  fi
done

last_index=$((${#wanted_versions[@]} - 1))
last_version=${wanted_versions[${last_index}]}

asdf global 'rust' "${last_version}"

log_success '[MacOS - 034] Rust installed!'
